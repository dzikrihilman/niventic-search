import { ScrollView, VerticalBox, LineEdit, Switch } from "std-widgets.slint";

export struct SearchResult {
    name: string,
    path: string,
    icon: string,
    icon-image: image,
    has-icon: bool,
}

export struct QuickAccessEntry {
    name: string,
    path: string,
    icon: string,
    icon-image: image,
}

export component AppWindow inherits Window {
    title: "Niventic Launcher";
    width: root.app-width * 1px;
    height: root.app-height * 1px;
    no-frame: true;
    always-on-top: true;
    icon: @image-url("assets/logo.png");
    background: transparent;
    default-font-family: "JetBrainsMono Nerd Font";
    
    in property <[SearchResult]> results: [];
    in-out property <string> search-text: "";
    in-out property <int> selected-index: 0;
    callback escape-pressed();
    callback search-changed(string);
    callback item-activated(int);
    callback quick-access-activated(string);
    callback save-settings();

    in-out property <bool> show-settings: false;

    in-out property <bool> cfg-run-at-startup: false;
    in-out property <string> cfg-width: "800";
    in-out property <string> cfg-height: "500";
    in-out property <string> cfg-font: "JetBrainsMono Nerd Font";
    in-out property <string> cfg-bg: "#2d2d30";
    in-out property <string> cfg-border-radius: "14";
    in-out property <string> cfg-border-width: "0.5";
    in-out property <string> cfg-border-color: "#a9a9a9";
    in-out property <string> cfg-opacity: "0.9";
    in-out property <string> cfg-hotkey-modifier: "Alt";
    in-out property <string> cfg-hotkey-key: "Space";
    in-out property <bool> hotkey-recording: false;
    in-out property <brush> app-bg: #2d2d30;
    in-out property <length> app-border-radius: 14px;
    in-out property <length> app-border-width: 0.5px;
    in-out property <brush> app-border-color: #a9a9a9;
    in-out property <string> app-font: "JetBrainsMono Nerd Font";
    in-out property <float> app-opacity: 0.9;
    in-out property <float> app-width: 800;
    in-out property <float> app-height: 500;
    callback pick-color(string);
    callback pick-qa-path(int);
    callback pick-qa-icon(int);
    in-out property <[QuickAccessEntry]> cfg-quick-access: [];
    public function focus-search() {
        search-input.focus();
    }

    Rectangle {
        x: 8px;
        y: 8px;
        width: parent.width - 16px;
        height: parent.height - 16px;
        background: root.app-bg;
        border-radius: root.app-border-radius;
        border-width: root.app-border-width;
        border-color: root.app-border-color;
        opacity: root.app-opacity;
        VerticalLayout {
            spacing: 0px;
            Rectangle {
                height: 56px;
                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 20px;
                    padding-top: 17px;
                    alignment: LayoutAlignment.start;
                    padding-bottom: 15px;
                    spacing: 12px;
                    Image {
                        source: @image-url("assets/search.svg");
                        vertical-alignment: ImageVerticalAlignment.center;
                        width: 22px;
                        height: 22px;
                        horizontal-alignment: ImageHorizontalAlignment.center;
                        horizontal-tiling: ImageTiling.none;
                        image-rendering: ImageRendering.smooth;
                        colorize: #909094;
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        search-input := TextInput {
                            width: 100%;
                            height: 100%;
                            text <=> root.search-text;
                            font-size: 17px;
                            color: #e8e8ea;
                            selection-background-color: #5a8fd4;
                            selection-foreground-color: #ffffff;
                            vertical-alignment: center;
                            edited => {
                                root.selected-index = 0;
                                root.search-changed(self.text);
                            }
                            key-pressed(event) => {
                                if event.text == Key.Escape {
                                    root.escape-pressed();
                                    return accept;
                                }
                                if event.text == Key.DownArrow {
                                    if root.selected-index < root.results.length - 1 {
                                        root.selected-index += 1;
                                    }
                                    return accept;
                                }
                                if event.text == Key.UpArrow {
                                    if root.selected-index > 0 {
                                        root.selected-index -= 1;
                                    }
                                    return accept;
                                }
                                if event.text == Key.Return {
                                    root.item-activated(root.selected-index);
                                    return accept;
                                }
                                return reject;
                            }
                        }

                        if root.search-text == "": Text {
                            width: 585px;
                            x: 0px;
                            text: "Search for apps, files, and folders.....";
                            font-size: 17px;
                            height: 33px;
                            color: #82828f;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: #3e3e42;
            }

            Rectangle {
                vertical-stretch: 1;
                clip: true;

                if root.show-settings: ScrollView {
                    VerticalLayout {
                        padding: 20px;
                        spacing: 16px;
                        HorizontalLayout {
                            alignment: space-between;
                            Text {
                                text: "Settings";
                                font-size: 18px;
                                font-weight: 700;
                                color: #e8e8ea;
                            }
                            Rectangle {
                                width: 60px;
                                height: 28px;
                                border-radius: 6px;
                                background: back-ta.has-hover ? #505053 : #434343;
                                animate background { duration: 100ms; }
                                Text {
                                    text: "← Back";
                                    font-size: 11px;
                                    color: #e8e8ea;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                back-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.show-settings = false;
                                    }
                                }
                            }
                        }
                        Text {
                            text: "SYSTEM";
                            font-size: 11px;
                            font-weight: 700;
                            color: #808084;
                            letter-spacing: 1px;
                        }

                        HorizontalLayout {
                            alignment: start;
                            spacing: 12px;
                            Switch {
                                text: "Run Niventic at System Startup";
                                checked <=> root.cfg-run-at-startup;
                            }
                        }
                        Text {
                            text: "HOTKEY";
                            font-size: 11px;
                            font-weight: 700;
                            color: #808084;
                            letter-spacing: 1px;
                        }
                        Rectangle {
                            height: 40px;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: root.hotkey-recording ? #5a9fff : #3e3e42;
                            background: root.hotkey-recording ? #2a3a5a : #1e1e20;
                            animate background { duration: 150ms; }
                            animate border-color { duration: 150ms; }
                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                alignment: center;
                                spacing: 8px;
                                Text {
                                    text: root.hotkey-recording ? "⏵ Press a key combination..." : root.cfg-hotkey-modifier + " + " + root.cfg-hotkey-key;
                                    font-size: 14px;
                                    font-weight: 500;
                                    color: root.hotkey-recording ? #5a9fff : #e8e8ea;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    animate color { duration: 150ms; }
                                }
                            }

                            hotkey-fs := FocusScope {
                                key-pressed(event) => {
                                    if root.hotkey-recording {
                                        if event.text != Key.Control && event.text != Key.Alt && event.text != Key.Shift && event.text != Key.Meta {
                                            if event.modifiers.alt {
                                                root.cfg-hotkey-modifier = "Alt";
                                            } else if event.modifiers.control {
                                                root.cfg-hotkey-modifier = "Ctrl";
                                            } else if event.modifiers.shift {
                                                root.cfg-hotkey-modifier = "Shift";
                                            } else if event.modifiers.meta {
                                                root.cfg-hotkey-modifier = "Win";
                                            }

                                            if event.text == " " {
                                                root.cfg-hotkey-key = "Space";
                                            } else if event.text == Key.Return {
                                                root.cfg-hotkey-key = "Enter";
                                            } else if event.text == Key.Tab {
                                                root.cfg-hotkey-key = "Tab";
                                            } else if event.text == Key.F1 {
                                                root.cfg-hotkey-key = "F1";
                                            } else if event.text == Key.F2 {
                                                root.cfg-hotkey-key = "F2";
                                            } else if event.text == Key.F3 {
                                                root.cfg-hotkey-key = "F3";
                                            } else if event.text == Key.F4 {
                                                root.cfg-hotkey-key = "F4";
                                            } else if event.text == Key.F5 {
                                                root.cfg-hotkey-key = "F5";
                                            } else if event.text == Key.F6 {
                                                root.cfg-hotkey-key = "F6";
                                            } else if event.text == Key.F7 {
                                                root.cfg-hotkey-key = "F7";
                                            } else if event.text == Key.F8 {
                                                root.cfg-hotkey-key = "F8";
                                            } else if event.text == Key.F9 {
                                                root.cfg-hotkey-key = "F9";
                                            } else if event.text == Key.F10 {
                                                root.cfg-hotkey-key = "F10";
                                            } else if event.text == Key.F11 {
                                                root.cfg-hotkey-key = "F11";
                                            } else if event.text == Key.F12 {
                                                root.cfg-hotkey-key = "F12";
                                            } else {
                                                root.cfg-hotkey-key = event.text;
                                            }
                                            root.hotkey-recording = false;
                                        }
                                        return accept;
                                    }
                                    return reject;
                                }
                            }

                            hotkey-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.hotkey-recording = !root.hotkey-recording;
                                    if root.hotkey-recording {
                                        hotkey-fs.focus();
                                    }
                                }
                            }
                        }

                        Text {
                            text: "⚠ Restart app to apply hotkey changes";
                            font-size: 10px;
                            color: #808084;
                            font-italic: true;
                        }
                        Text {
                            text: "APPEARANCE";
                            font-size: 11px;
                            font-weight: 700;
                            color: #808084;
                            letter-spacing: 1px;
                        }
                        HorizontalLayout {
                            spacing: 12px;
                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text {
                                    text: "Width";
                                    font-size: 11px;
                                    color: #a0a0a4;
                                }

                                LineEdit {
                                    text <=> root.cfg-width;
                                }
                            }

                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text {
                                    text: "Height";
                                    font-size: 11px;
                                    color: #a0a0a4;
                                }

                                LineEdit {
                                    text <=> root.cfg-height;
                                }
                            }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: "Font Family";
                                font-size: 11px;
                                color: #a0a0a4;
                            }

                            LineEdit {
                                text <=> root.cfg-font;
                            }
                        }
                        HorizontalLayout {
                            spacing: 12px;
                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text {
                                    text: "Background";
                                    font-size: 11px;
                                    color: #a0a0a4;
                                }

                                HorizontalLayout {
                                    spacing: 6px;
                                    LineEdit {
                                        text <=> root.cfg-bg;
                                        horizontal-stretch: 1;
                                    }
                                    Rectangle {
                                        width: 32px;
                                        height: 32px;
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: #555;
                                        background: root.app-bg;
                                        bg-pick-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.pick-color("bg");
                                            }
                                        }
                                    }
                                }
                            }

                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text {
                                    text: "Border Color";
                                    font-size: 11px;
                                    color: #a0a0a4;
                                }

                                HorizontalLayout {
                                    spacing: 6px;
                                    LineEdit {
                                        text <=> root.cfg-border-color;
                                        horizontal-stretch: 1;
                                    }
                                    Rectangle {
                                        width: 32px;
                                        height: 32px;
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: #555;
                                        background: root.app-border-color;
                                        border-pick-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.pick-color("border");
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        HorizontalLayout {
                            spacing: 12px;
                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text {
                                    text: "Border Radius";
                                    font-size: 11px;
                                    color: #a0a0a4;
                                }

                                LineEdit {
                                    text <=> root.cfg-border-radius;
                                }
                            }
                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text {
                                    text: "Border Width";
                                    font-size: 11px;
                                    color: #a0a0a4;
                                }

                                LineEdit {
                                    text <=> root.cfg-border-width;
                                }
                            }
                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text {
                                    text: "Opacity";
                                    font-size: 11px;
                                    color: #a0a0a4;
                                }

                                LineEdit {
                                    text <=> root.cfg-opacity;
                                    placeholder-text: "0.0 - 1.0";
                                }
                            }
                        }
                        Text {
                            text: "QUICK ACCESS";
                            font-size: 11px;
                            font-weight: 700;
                            color: #808084;
                            letter-spacing: 1px;
                        }

                        for item[idx] in root.cfg-quick-access: HorizontalLayout {
                            spacing: 8px;
                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text {
                                    text: "Name";
                                    font-size: 10px;
                                    color: #606064;
                                }

                                LineEdit {
                                    text: item.name;
                                    edited(val) => {
                                        item.name = val;
                                    }
                                }
                            }

                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 2;
                                Text {
                                    text: "Path";
                                    font-size: 10px;
                                    color: #606064;
                                }

                                HorizontalLayout {
                                    spacing: 4px;
                                    LineEdit {
                                        text: item.path;
                                        horizontal-stretch: 1;
                                        edited(val) => {
                                            item.path = val;
                                        }
                                    }
                                    Rectangle {
                                        width: 32px;
                                        height: 32px;
                                        border-radius: 6px;
                                        background: qa-path-ta.has-hover ? #505053 : #3a3a3d;
                                        animate background { duration: 100ms; }
                                        Image {
                                            source: @image-url("assets/folder-open.svg");
                                            width: 16px;
                                            height: 16px;
                                            colorize: qa-path-ta.has-hover ? #e8e8ea : #a0a0a4;
                                            animate colorize { duration: 100ms; }
                                        }

                                        qa-path-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.pick-qa-path(idx);
                                            }
                                        }
                                    }
                                }
                            }

                            VerticalLayout {
                                spacing: 4px;
                                horizontal-stretch: 1;
                                Text {
                                    text: "Icon";
                                    font-size: 10px;
                                    color: #606064;
                                }

                                HorizontalLayout {
                                    spacing: 4px;
                                    LineEdit {
                                        text: item.icon;
                                        horizontal-stretch: 1;
                                        edited(val) => {
                                            item.icon = val;
                                        }
                                    }
                                    Rectangle {
                                        width: 32px;
                                        height: 32px;
                                        border-radius: 6px;
                                        background: qa-icon-ta.has-hover ? #505053 : #3a3a3d;
                                        animate background { duration: 100ms; }
                                        Image {
                                            source: @image-url("assets/folder-open.svg");
                                            width: 16px;
                                            height: 16px;
                                            colorize: qa-icon-ta.has-hover ? #e8e8ea : #a0a0a4;
                                            animate colorize { duration: 100ms; }
                                        }

                                        qa-icon-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.pick-qa-icon(idx);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        HorizontalLayout {
                            alignment: end;
                            Rectangle {
                                width: 80px;
                                height: 32px;
                                border-radius: 8px;
                                background: save-ta.has-hover ? #4a8ae6 : #5a9fff;
                                animate background { duration: 100ms; }
                                Text {
                                    text: "Save";
                                    font-size: 13px;
                                    font-weight: 600;
                                    color: #ffffff;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                save-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.save-settings();
                                    }
                                }
                            }
                        }
                    }
                }
                if !root.show-settings && root.results.length > 0: ScrollView {
                    VerticalLayout {
                        padding: 6px;
                        spacing: 2px;
                        for result[idx] in root.results: Rectangle {
                            height: 52px;
                            border-radius: 8px;
                            background: idx == root.selected-index ? #454548 : transparent;
                            animate background { duration: 80ms; }
                            HorizontalLayout {
                                spacing: 0px;
                                Rectangle {
                                    y: 12px;
                                    width: 3px;
                                    height: 25px;
                                    border-radius: 2px;
                                    background: idx == root.selected-index ? #5a9fff : transparent;
                                    animate background { duration: 80ms; }
                                }

                                Rectangle {
                                    width: 12px;
                                }
                                Rectangle {
                                    width: 36px;
                                    height: 36px;
                                    border-radius: 8px;
                                    background: #2a2a2d;
                                    y: 7px;

                                    if result.has-icon: Image {
                                        source: result.icon-image;
                                        width: 24px;
                                        height: 24px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        image-fit: contain;
                                    }

                                    if !result.has-icon: Image {
                                        source: @image-url("assets/apps.svg");
                                        width: 22px;
                                        height: 22px;
                                        colorize: #808084;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Rectangle {
                                    width: 12px;
                                }
                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    horizontal-stretch: 1;
                                    Text {
                                        text: result.name;
                                        font-size: 14px;
                                        font-weight: 500;
                                        color: #e8e8ea;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: "App";
                                        font-size: 11px;
                                        color: #6b9fff;
                                    }
                                }

                                Rectangle {
                                    width: 12px;
                                }
                            }

                            TouchArea {
                                mouse-cursor: MouseCursor.pointer;
                                clicked => {
                                    root.selected-index = idx;
                                    root.item-activated(idx);
                                }
                            }
                        }
                    }
                }
                if !root.show-settings && root.results.length == 0 && root.search-text != "": Rectangle {
                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        Text {
                            text: "No results found";
                            font-size: 15px;
                            color: #808084;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "Try a different search term";
                            font-size: 12px;
                            color: #a0a0a4;
                            horizontal-alignment: center;
                        }
                    }
                }
                if !root.show-settings && root.search-text == "": VerticalLayout {
                    padding: 24px;
                    padding-top: 20px;
                    spacing: 8px;
                    alignment: LayoutAlignment.space-between;
                    Text {
                        text: "QUICK ACCESS";
                        visible: false;
                        wrap: TextWrap.no-wrap;
                        font-size: 11px;
                        font-weight: 700;
                        accessible-role: AccessibleRole.none;
                        color: #808084;
                        letter-spacing: 1px;
                    }
                    HorizontalLayout {
                        spacing: 50px;
                        alignment: center;
                        for qa-item[qa-idx] in root.cfg-quick-access: VerticalLayout {
                            spacing: 6px;
                            alignment: center;
                            Rectangle {
                                width: 52px;
                                height: 52px;
                                border-radius: 12px;
                                background: qa-grid-ta.has-hover ? #505053 : #434343;
                                animate background { duration: 120ms; }
                                Image {
                                    source: qa-item.icon-image;
                                    width: 28px;
                                    height: 28px;
                                    colorize: qa-grid-ta.has-hover ? #ffffff : #c7c7c7;
                                    animate colorize { duration: 120ms; }
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                qa-grid-ta := TouchArea {
                                    clicked => {
                                        root.quick-access-activated(qa-item.name);
                                    }
                                    mouse-cursor: pointer;
                                }
                            }

                            Text {
                                text: qa-item.name;
                                font-size: 10px;
                                color: #a0a0a4;
                                horizontal-alignment: center;
                            }
                        }
                    }
                    Rectangle {
                        height: 8px;
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        HorizontalLayout {
                            width: 22px;
                            height: 22px;
                            Rectangle {
                                width: 100%;
                                background: root.show-settings ? #5a9fff : settings-footer-ta.has-hover ? #505053 : #3a3a3d;
                                border-radius: 4px;
                                animate background { duration: 100ms; }
                                settings-footer-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.show-settings = !root.show-settings;
                                    }
                                }

                                Image {
                                    source: @image-url("assets/settings-2.svg");
                                    width: 14px;
                                    height: 14px;
                                    colorize: root.show-settings ? #ffffff : settings-footer-ta.has-hover ? #e8e8ea : #a0a0a4;
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 24px;
                            alignment: end;
                            HorizontalLayout {
                                spacing: 6px;
                                padding-top: 4px;
                                HorizontalLayout {
                                    spacing: 0;
                                    Image {
                                        source: @image-url("assets/arrowup.svg");
                                        width: 14px;
                                        height: 14px;
                                        colorize: #a0a0a4;
                                    }

                                    Image {
                                        source: @image-url("assets/arrowdown.svg");
                                        width: 14px;
                                        height: 14px;
                                        colorize: #a0a0a4;
                                    }
                                }

                                Text {
                                    text: "Navigate";
                                    font-size: 11px;
                                    color: #a0a0a4;
                                }
                            }

                            HorizontalLayout {
                                spacing: 6px;
                                padding-top: 4px;
                                Image {
                                    source: @image-url("assets/enter.svg");
                                    width: 14px;
                                    height: 14px;
                                    colorize: #a0a0a4;
                                }

                                Text {
                                    text: "Open";
                                    font-size: 11px;
                                    color: #a0a0a4;
                                }
                            }

                            HorizontalLayout {
                                spacing: 6px;
                                padding-top: 4px;
                                Rectangle {
                                    width: 28px;
                                    height: 18px;
                                    border-radius: 4px;
                                    border-width: 1px;
                                    border-color: #a0a0a4;
                                    Text {
                                        text: "Esc";
                                        font-size: 9px;
                                        color: #a0a0a4;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Text {
                                    text: "Close";
                                    font-size: 11px;
                                    color: #a0a0a4;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
